  m_SharedData: {fileID: 11400000, guid: f1c32955ccc194fe1a78d048682da54b, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 372236288
    m_Localized: "\xC7\xF6zmeye haz\u0131r m\u0131s\u0131n?"
    m_Metadata:
      m_Items: []
  - m_Id: 376430592
    m_Localized: "S\xFCre bitmeden \xF6nce her blo\u011Fu e\u015Fle\u015Fen \xE7\u0131k\u0131\u015F
      kap\u0131s\u0131na kayd\u0131r."
    m_Metadata:
      m_Items: []
  - m_Id: 376430593
    m_Localized: "B\xF6l\xFCm\xFC Ba\u015Flat"
    m_Metadata:
      m_Items: []
  - m_Id: 376430594
    m_Localized: "B\xF6l\xFCm Tamamland\u0131!"
    m_Metadata:
      m_Items: []
  - m_Id: 376430595
    m_Localized: Harika hamle. Seriyi devam ettir.
    m_Metadata:
      m_Items: []
  - m_Id: 376430596
    m_Localized: Devam Et
    m_Metadata:
      m_Items: []
  - m_Id: 376430597
    m_Localized: "Kap\u0131ya ula\u015F\u0131lamad\u0131"
    m_Metadata:
      m_Items: []
  - m_Id: 376430598
    m_Localized: "\xC7ok yak\u0131nd\u0131n. Bir kez daha dene."
    m_Metadata:
      m_Items: []
  - m_Id: 376430599
    m_Localized: Tekrar Dene
    m_Metadata:
      m_Items: []
  - m_Id: 376430600
    m_Localized: "T\xFCm B\xF6l\xFCmleri Ge\xE7tin!"
    m_Metadata:
      m_Items: []
  - m_Id: 376430601
    m_Localized: "\u0130lerlemen s\u0131f\u0131rland\u0131. 1. b\xF6l\xFCmden tekrar
      ba\u015Fla."
    m_Metadata:
      m_Items: []
  - m_Id: 376430602
    m_Localized: Oyna
    m_Metadata:
      m_Items: []
  - m_Id: 376430603
    m_Localized: "B\xF6l\xFCm"
    m_Metadata:
      m_Items: []
  - m_Id: 376430604
    m_Localized: "S\xFCre"
    m_Metadata:
      m_Items: []
  - m_Id: 376430605
    m_Localized: Ayarlar
    m_Metadata:
      m_Items: []
  - m_Id: 376430606
    m_Localized: "M\xFCzik"
    m_Metadata:
      m_Items: []
  - m_Id: 376430607
    m_Localized: SFX
    m_Metadata:
      m_Items: []
  - m_Id: 376430608
    m_Localized: Dil
    m_Metadata:
      m_Items: []
  - m_Id: 376430609
    m_Localized: "Yeni \xD6zellik A\xE7\u0131ld\u0131"
    m_Metadata:
      m_Items: []
  - m_Id: 376430610
    m_Localized: Sonraki
    m_Metadata:
      m_Items: []
  - m_Id: 376430611
    m_Localized: "S\xFCreli \xC7\u0131k\u0131\u015F"
    m_Metadata:
      m_Items: []
  - m_Id: 376430612
    m_Localized: "Bu block belirli say\u0131da hamle i\xE7inde \xE7\u0131k\u0131\u015F
      yapmak zorundad\u0131r. Her hareket sonras\u0131 saya\xE7 azal\u0131r. Saya\xE7
      bitmeden kap\u0131ya ula\u015Ft\u0131r\u0131lmazsa level ba\u015Far\u0131s\u0131z
      olur."
    m_Metadata:
      m_Items: []
  - m_Id: 376430613
    m_Localized: "Kilit A\xE7\u0131lana Kadar Kilitli"
    m_Metadata:
      m_Items: []
  - m_Id: 376430614
    m_Localized: "Bu block ba\u015Flang\u0131\xE7ta hareket edemez. \xD6nce belirli
      say\u0131da ba\u015Fka block'un \xE7\u0131k\u0131\u015F yapmas\u0131 gerekir.
      Ko\u015Ful tamamlan\u0131nca aktif hale gelir."
    m_Metadata:
      m_Items: []
  - m_Id: 376430615
    m_Localized: Yatay Hareket
    m_Metadata:
      m_Items: []
  - m_Id: 376430616
    m_Localized: "Bu block yaln\u0131zca sa\u011Fa ve sola hareket edebilir."
    m_Metadata:
      m_Items: []
  - m_Id: 376430617
    m_Localized: Dikey Hareket
    m_Metadata:
      m_Items: []
  - m_Id: 376430618
    m_Localized: "Bu block yaln\u0131zca yukar\u0131 ve a\u015Fa\u011F\u0131 hareket
      edebilir."
    m_Metadata:
      m_Items: []
  - m_Id: 376430619
    m_Localized: "\u0130\xE7 \u0130\xE7e \u015Eekil"
    m_Metadata:
      m_Items: []
  - m_Id: 376430620
    m_Localized: "Bu block i\xE7 i\xE7e katmanlar i\xE7erir. D\u0131\u015F katman
      \xE7\u0131k\u0131\u015F yapt\u0131\u011F\u0131nda bir sonraki i\xE7 katman ayn\u0131
      konumda ortaya \xE7\u0131kar ve devam eder."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
