  m_TableData:
  - m_Id: 372236288
    m_Localized: "C\xF6zmeye hazir misin?"
    m_Metadata:
      m_Items: []
  - m_Id: 376430592
    m_Localized: "S\xFCre bitmeden \xF6nce her blo\u011Fu e\u015Fle\u015Fen \xE7\u0131k\u0131\u015F
      kap\u0131s\u0131na kayd\u0131r."
    m_Metadata:
      m_Items: []
  - m_Id: 376430593
    m_Localized: "B\xF6l\xFCm\xFC Ba\u015Flat"
    m_Metadata:
      m_Items: []
  - m_Id: 376430594
    m_Localized: "B\xF6l\xFCm Tamamland\u0131!"
    m_Metadata:
      m_Items: []
  - m_Id: 376430595
    m_Localized: Harika hamle. Seriyi devam ettir.
    m_Metadata:
      m_Items: []
  - m_Id: 376430596
    m_Localized: Devam Et
    m_Metadata:
      m_Items: []
  - m_Id: 376430597
    m_Localized: "S\xFCre Doldu"
    m_Metadata:
      m_Items: []
  - m_Id: 376430598
    m_Localized: "\xC7ok yak\u0131nd\u0131n. O rotay\u0131 bir kez daha dene."
    m_Metadata:
      m_Items: []
  - m_Id: 376430599
    m_Localized: Tekrar Dene
    m_Metadata:
      m_Items: []
  - m_Id: 376430600
    m_Localized: "T\xFCm B\xF6l\xFCmleri Ge\xE7tin!"
    m_Metadata:
      m_Items: []
  - m_Id: 376430601
    m_Localized: "Harika bir turdu. Ba\u015Fa d\xF6n\xFCp bir kez daha oynamaya haz\u0131r
      m\u0131s\u0131n?"
    m_Metadata:
      m_Items: []
  - m_Id: 376430602
    m_Localized: "Yeniden Ba\u015Flat"
    m_Metadata:
      m_Items: []
  - m_Id: 376430603
    m_Localized: "B\xF6l\xFCm"
    m_Metadata:
      m_Items: []
  - m_Id: 376430604
    m_Localized: "S\xFCre"
    m_Metadata:
      m_Items: []
  - m_Id: 376430605
    m_Localized: Ayarlar
    m_Metadata:
      m_Items: []
  - m_Id: 376430606
    m_Localized: "M\xFCzik"
    m_Metadata:
      m_Items: []
